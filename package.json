{
  "name": "gf-magazine",
  "private": true,
  "version": "0.1.0",
  "description": "GF Magazine — headless Next.js + Sanity monorepo",
  "scripts": {
    "claw-dev": "npm run claude:local",
    "dev": "concurrently \"pnpm --filter web dev\" \"pnpm --filter studio dev\" --names \"web,studio\" --prefix-colors \"cyan,magenta\"",
    "dev:web": "pnpm --filter web dev",
    "dev:studio": "pnpm --filter studio dev",
    "build": "pnpm --filter web build",
    "build:web": "pnpm --filter web build",
    "build:studio": "pnpm --filter studio build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "type-check": "pnpm --filter web type-check && pnpm --filter studio type-check",
    "status": "npm run ollama:status",
    "doctor": "npm run ollama:doctor",
    "ollama:status": "node scripts/dev.js --status",
    "ollama:doctor": "node scripts/dev.js --doctor",
    "ollama:install": "node scripts/install-models.js",
    "ollama:compare": "node scripts/model-compare.js",
    "cascade": "node scripts/cascade-launcher.js",
    "cascade:select": "node scripts/cascade-launcher.js --select",
    "dev:local": "node scripts/local-dev.js",
    "claude:local": "powershell -ExecutionPolicy Bypass -File scripts/run-local-agent.ps1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "prettier": "^3.5.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "sanity>react": "18 || 19"
      }
    }
  },
  "engines": {
    "node": "24.x",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "lucide-react": "^1.7.0",
    "react-pageflip": "^2.0.3"
  }
}
