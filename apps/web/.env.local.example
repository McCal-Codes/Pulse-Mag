# ─── Sanity ────────────────────────────────────────────────────────────────
# Project settings from sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-01

# Server-side equivalents (used by getSanityServerClient — never exposed to browser)
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production

# Viewer-role token for server fetches and draft preview
# Get from: sanity.io/manage → API → Tokens → Add API Token (Viewer role)
SANITY_API_READ_TOKEN=

# Secret for /api/preview — generate with: openssl rand -hex 32
SANITY_PREVIEW_SECRET=

# ─── Sentry ────────────────────────────────────────────────────────────────
# Public DSN — safe to expose in the browser bundle
# Get from: sentry.io → Your Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# Build-time only — used by the Sentry webpack plugin to upload source maps
# Get from: sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
