# ─── Sanity ────────────────────────────────────────────────────────────────
# Project settings from sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-01

# Server-side equivalents (used by getSanityServerClient — never exposed to browser)
SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production

# Viewer-role token for server fetches and draft preview
# Get from: sanity.io/manage → API → Tokens → Add API Token (Viewer role)
SANITY_API_READ_TOKEN=

# Secret for /api/preview — generate with: openssl rand -hex 32
SANITY_PREVIEW_SECRET=

# ─── Sentry ────────────────────────────────────────────────────────────────
# Public DSN — safe to expose in the browser bundle
# Get from: sentry.io → Your Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=

# Build-time only — used by the Sentry webpack plugin to upload source maps
# Get from: sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Wix ───────────────────────────────────────────────────────────────────
# Wix API credentials for Events SDK integration
# Site: https://pulse24.wixsite.com/pulse
#
# To get your API Key:
# 1. Go to Wix Dashboard → Settings → Headless API
# 2. Create a new API Key or use existing one
# 3. Copy the API Key (starts with IST.)
#
# WIX_API_KEY=IST.xxx...
# WIX_SITE_ID=your-site-id

# ─── Wix Events OAuth (Optional - for advanced features) ──────────────────────
# For full OAuth app setup (required for ticket sales/RSVPs with user auth):
# 1. Go to Wix Dashboard → Settings → OAuth Apps
# 2. Create a new OAuth app
# 3. Add redirect URI: https://pulseliterary.com/api/auth/wix/callback
# 4. Copy Client ID and Secret
#
# WIX_OAUTH_CLIENT_ID=your-oauth-client-id
# WIX_OAUTH_CLIENT_SECRET=your-oauth-client-secret
# WIX_OAUTH_REDIRECT_URI=https://pulseliterary.com/api/auth/wix/callback
